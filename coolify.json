{
  "$schema": "https://coolify.io/schemas/deploy.json",
  "name": "poetry-app",
  "version": "1.0.0",
  "description": "爱国诗词集 — Next.js + SQLite",
  "icon": "book",
  "categories": ["nextjs", "nodejs"],
  "environment": [
    {
      "key": "NODE_ENV",
      "value": "production"
    },
    {
      "key": "PORT",
      "value": "3000"
    }
  ],
  "build": {
    "method": "nixpacks",
    "command": "npm install && npm run build",
    "port": 3000,
    "healthCheckPath": "/"
  },
  "settings": {
    "instantDeploy": true,
    "previewUrlEnabled": false,
    "useMarkerAnalyzer": false
  },
  "domains": [
    {
      "host": "shici.yourdomain.com",
      "https": true,
      "enableProxy": true
    }
  ]
}