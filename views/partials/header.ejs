<header class="sticky top-0 z-30 bg-[#faf8f5]/95 backdrop-blur-sm border-b border-[#e8e2d8]" style="padding-top: max(0px, env(safe-area-inset-top));">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-2 sm:py-2.5">
    <div class="flex flex-nowrap items-center gap-2 sm:gap-3 min-w-0">
      <a href="/" class="w-8 h-8 sm:w-7 sm:h-7 rounded-full bg-[#1a1814] flex items-center justify-center shrink-0 no-underline hover:opacity-90 [touch-action:manipulation]" aria-label="回首页">
        <span class="text-[#c5973a] text-xs font-serif font-bold">詩</span>
      </a>
      <% if (typeof headerBrandOnly === 'undefined' || !headerBrandOnly) { %>
        <h1 class="text-sm sm:text-base font-serif font-semibold text-[#1a1814] tracking-wide truncate shrink-0 max-w-[7rem] sm:max-w-[11rem] md:max-w-[14rem]">
          <%= title %>
        </h1>
      <% } %>
      <form action="/search" method="get" class="flex-1 min-w-0">
        <div class="relative flex items-center">
          <input
            type="search"
            name="q"
            enterkeyhint="search"
            placeholder="搜索诗词、作者、内容分类…"
            value="<%= typeof query !== 'undefined' ? query : '' %>"
            class="w-full min-w-0 h-9 sm:h-10 pl-2.5 sm:pl-3 pr-11 sm:pr-12 rounded-sm border border-[#e8e2d8] bg-white
                   text-sm text-[#1a1814] placeholder:text-[#b0a89e]
                   focus:outline-none focus:border-[#c5973a] focus:ring-1 focus:ring-[#c5973a]/30
                   font-sans transition-colors"
          >
          <button
            type="submit"
            class="absolute right-0.5 top-1/2 -translate-y-1/2
                   min-w-[2.25rem] min-h-[2.25rem] w-9 h-9 sm:w-9 sm:h-9 rounded-sm bg-[#1a1814] hover:bg-[#c5973a] text-white
                   flex items-center justify-center transition-colors shrink-0 [touch-action:manipulation]"
            aria-label="搜索"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <circle cx="11" cy="11" r="6" stroke-width="1.5"/>
              <path d="m16.5 16.5 3 3" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </button>
        </div>
      </form>
    </div>
  </div>
</header>
