<!DOCTYPE html>
<html lang="zh-CN" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: { ink:'#1a1814', warm:'#f7f3ee', gold:'#c5973a', goldLt:'#e8d5a3', cream:'#faf8f5', muted:'#8b8178', stroke:'#e8e2d8' },
          fontFamily: { serif: ['Noto Serif SC','Georgia','serif'], sans: ['Inter','system-ui','sans-serif'] },
        }
      }
    }
  </script>
  <style>
    * { font-family: 'Inter','Noto Serif SC', sans-serif; }
    body { background: #faf8f5; }
    .tab-btn { padding: 10px 16px; font-size: 0.8rem; font-family: 'Inter', sans-serif; border-bottom: 2px solid transparent; color: #8b8178; transition: all 0.15s; white-space: nowrap; }
    .tab-btn.active { color: #c5973a; border-bottom-color: #c5973a; }
    .tag-card { border: 1px solid #e8e2d8; background: white; transition: all 0.15s; }
    .tag-card:hover { border-color: #c5973a; box-shadow: 0 4px 12px #c5973a12; }
  </style>
</head>
<body class="min-h-full flex flex-col antialiased">

<header class="sticky top-0 z-30 bg-[#faf8f5]/95 backdrop-blur-sm border-b border-[#e8e2d8]">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-3">
    <div class="flex items-center gap-3">
      <div class="w-7 h-7 rounded-full bg-[#1a1814] flex items-center justify-center shrink-0">
        <span class="text-[#c5973a] text-xs font-serif font-bold">詩</span>
      </div>
      <h1 class="text-base font-serif font-semibold text-[#1a1814]"><%= title %></h1>
    </div>
  </div>
</header>

<!-- Tabs -->
<div class="sticky top-[57px] z-20 bg-white border-b border-[#e8e2d8]">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex overflow-x-auto -mb-0">
      <button onclick="showTab('categories')" id="btn-categories" class="tab-btn active">分类 <span class="ml-1 text-[#8b8178]">(<%= categories.length %>)</span></button>
      <button onclick="showTab('authors')"     id="btn-authors"     class="tab-btn">作者 <span class="ml-1 text-[#8b8178]">(<%= authors.length %>)</span></button>
      <button onclick="showTab('types')"       id="btn-types"      class="tab-btn">类型 <span class="ml-1 text-[#8b8178]">(<%= poetryTypes.length %>)</span></button>
      <button onclick="showTab('custom')"      id="btn-custom"     class="tab-btn">标签 <span class="ml-1 text-[#8b8178]">(<%= customTags.length %>)</span></button>
    </div>
  </div>
</div>

<main class="flex-1 max-w-6xl mx-auto px-4 sm:px-6 py-8 w-full">

  <!-- Categories -->
  <div id="panel-categories" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
    <% categories.forEach(item => { %>
      <a href="/search?q=<%= encodeURIComponent(item.name) %>" class="tag-card rounded-sm p-4 block">
        <div class="font-serif font-medium text-[#1a1814] truncate text-sm"><%= item.name %></div>
        <div class="text-xs text-[#c5973a] mt-1 font-sans"><%= item.count %> 首</div>
      </a>
    <% }) %>
    <% if (categories.length === 0) { %>
      <p class="col-span-5 text-sm text-[#8b8178] font-serif py-8 text-center">暂无分类</p>
    <% } %>
  </div>

  <!-- Authors -->
  <div id="panel-authors" class="hidden grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
    <% authors.forEach(item => { %>
      <a href="/search?q=<%= encodeURIComponent(item.name) %>" class="tag-card rounded-sm p-4 block">
        <div class="font-serif font-medium text-[#1a1814] truncate text-sm"><%= item.name %></div>
        <div class="text-xs text-[#c5973a] mt-1 font-sans"><%= item.count %> 首</div>
      </a>
    <% }) %>
  </div>

  <!-- Types -->
  <div id="panel-types" class="hidden grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
    <% poetryTypes.forEach(item => { %>
      <a href="/search?q=<%= encodeURIComponent(item.name) %>" class="tag-card rounded-sm p-4 block">
        <div class="font-serif font-medium text-[#1a1814] truncate text-sm"><%= item.name %></div>
        <div class="text-xs text-[#c5973a] mt-1 font-sans"><%= item.count %> 首</div>
      </a>
    <% }) %>
    <% if (poetryTypes.length === 0) { %>
      <p class="col-span-5 text-sm text-[#8b8178] font-serif py-8 text-center">暂无类型</p>
    <% } %>
  </div>

  <!-- Custom Tags -->
  <div id="panel-custom" class="hidden grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
    <% customTags.forEach(item => { %>
      <a href="/search?q=<%= encodeURIComponent(item.name) %>" class="tag-card rounded-sm p-4 block">
        <div class="font-serif font-medium text-[#1a1814] truncate text-sm">#<%= item.name %></div>
        <div class="text-xs text-[#8b8178] mt-1 font-sans"><%= item.count %> 首</div>
      </a>
    <% }) %>
    <% if (customTags.length === 0) { %>
      <p class="col-span-5 text-sm text-[#8b8178] font-serif py-8 text-center">暂无标签</p>
    <% } %>
  </div>

</main>

<%- include('partials/nav') %>

<script>
  function showTab(name) {
    document.querySelectorAll('[id^="panel-"]').forEach(p => p.classList.add('hidden'));
    document.getElementById('panel-' + name).classList.remove('hidden');
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.getElementById('btn-' + name).classList.add('active');
  }
</script>
</body>
</html>