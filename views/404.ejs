<!DOCTYPE html>
<html lang="zh-CN" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>404 — 页面未找到</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    * { font-family: 'Inter','Noto Serif SC', sans-serif; }
    body { background: #faf8f5; }
  </style>
</head>
<body class="min-h-full flex flex-col items-center justify-center">

  <div class="text-center px-6">
    <div class="w-16 h-16 rounded-full bg-[#1a1814] flex items-center justify-center mx-auto mb-6">
      <span class="text-3xl font-serif text-[#c5973a]">?</span>
    </div>
    <h1 class="text-6xl font-serif font-bold text-[#1a1814] mb-3">404</h1>
    <p class="text-lg text-[#8b8178] font-serif mb-8"><%= typeof message !== 'undefined' && message ? message : '页面未找到' %></p>
    <a href="/" class="inline-block px-6 py-3 bg-[#1a1814] text-white font-sans text-sm rounded-sm hover:bg-[#c5973a] transition-colors">
      返回首页
    </a>
  </div>

</body>
</html>