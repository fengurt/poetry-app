<!DOCTYPE html>
<html lang="zh-CN" class="h-full">
<head>
  <meta charset="UTF-8">
  <%- include('partials/mobile-head') %>
  <title><%= poem.title %> — 爱国诗词集</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            ink:    '#1a1814',
            warm:   '#f7f3ee',
            gold:   '#c5973a',
            goldLt: '#e8d5a3',
            cream:  '#faf8f5',
            muted:  '#8b8178',
            stroke: '#e8e2d8',
          },
          fontFamily: {
            serif: ['Noto Serif SC', 'Georgia', 'serif'],
            sans:  ['Inter', 'system-ui', 'sans-serif'],
          },
        }
      }
    }
  </script>
  <style>
    * { font-family: 'Inter', 'Noto Serif SC', sans-serif; }
    body { background: #faf8f5; }

    .poem-content { font-family: 'Noto Serif SC', serif; line-height: 2.2; overflow-wrap: anywhere; word-break: break-word; }
    .poem-line { font-size: 1.0625rem; color: #2c2824; display: block; }
    @media (min-width: 640px) {
      .poem-line { font-size: 1.15rem; }
    }
    .poem-line.indent { padding-left: 1.25rem; }
    @media (min-width: 640px) {
      .poem-line.indent { padding-left: 2rem; }
    }
    .chip-author { background: #1a1814; color: #f7f3ee; border-radius: 2px; padding: 2px 10px; font-size: 0.75rem; }
    .chip-cat { border: 1px solid #c5973a; color: #c5973a; border-radius: 2px; padding: 2px 10px; font-size: 0.75rem; }
    .chip-meta { border: 1px solid #e8e2d8; color: #8b8178; border-radius: 2px; padding: 2px 8px; font-size: 0.7rem; }
  </style>
</head>
<body class="min-h-full flex flex-col antialiased pad-bottom-nav">

<header class="sticky top-0 z-30 bg-[#faf8f5]/95 backdrop-blur-sm border-b border-[#e8e2d8]" style="padding-top: max(0px, env(safe-area-inset-top));">
  <div class="max-w-4xl mx-auto px-4 py-2.5 sm:py-3 flex items-center gap-3 sm:gap-4 min-w-0">
    <a href="/" class="flex items-center gap-2 text-sm text-[#8b8178] hover:text-[#c5973a] transition-colors shrink-0 min-h-[2.75rem] min-w-[2.75rem] sm:min-w-0 px-1 -ml-1 rounded-sm [touch-action:manipulation] active:opacity-80" aria-label="返回首页">
      <svg class="w-5 h-5 sm:w-4 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-width="1.5" stroke-linecap="round" d="M15 19l-7-7 7-7"/>
      </svg>
      <span class="hidden sm:inline">返回</span>
    </a>
    <div class="w-6 h-6 rounded-full bg-[#1a1814] flex items-center justify-center">
      <span class="text-[#c5973a] text-xs font-serif font-bold">詩</span>
    </div>
    <p class="font-serif font-semibold text-[#1a1814] text-base truncate m-0" aria-hidden="true"><%= poem.title %></p>
  </div>
</header>

<main class="flex-1 max-w-4xl mx-auto px-4 py-5 sm:py-8 w-full">

  <!-- Poem card -->
  <div class="bg-white border border-[#e8e2d8] rounded-sm p-5 sm:p-8 md:p-12 mb-6 sm:mb-8"
       style="box-shadow: 4px 4px 0 #c5973a18;">

    <!-- Title block -->
    <div class="text-center mb-8">
      <h1 id="poem-title" class="text-2xl sm:text-3xl md:text-4xl font-serif font-semibold text-[#1a1814] leading-snug mb-2 px-1">
        <%= poem.title %>
      </h1>
      <% if (poem.subtitle) { %>
        <p class="text-[#8b8178] text-base font-serif"><%= poem.subtitle %></p>
      <% } %>
    </div>

    <!-- Meta chips -->
    <div class="flex flex-wrap items-center justify-center gap-2 mb-8 sm:mb-10 px-1">
      <a href="/author/<%= encodeURIComponent(poem.author_name) %>" class="chip-author font-sans no-underline inline-flex items-center min-h-[2.25rem] px-2 [touch-action:manipulation] active:opacity-90"><%= poem.author_name %></a>
      <% if (poem.poetry_type) { %>
        <span class="chip-meta font-sans" title="体裁"><%= poem.poetry_type %></span>
      <% } %>
      <% if (poem.category) { %>
        <span class="chip-cat font-sans" title="内容分类"><%= poem.category %></span>
      <% } %>
    </div>

    <!-- Poem body -->
    <div class="poem-content max-w-2xl mx-auto">
      <% const lines = poem.content.split('\n'); %>
      <% lines.forEach((line, i) => { %>
        <% if (line.trim()) { %>
          <span class="poem-line<%= i > 0 && (lines[i-1]?.trim()) ? ' indent' : '' %>"><%= line %></span>
        <% } else { %>
          <br>
        <% } %>
      <% }) %>
    </div>

    <!-- Source / Notes -->
    <% if (poem.source || poem.notes) { %>
      <div class="mt-10 pt-6 border-t border-[#e8e2d8]">
        <% if (poem.source) { %>
          <p class="text-sm text-[#8b8178]">
            <span class="text-[#c5973a] font-sans text-xs uppercase tracking-wider mr-2">来源</span>
            <span class="font-serif"><%= poem.source %></span>
          </p>
        <% } %>
        <% if (poem.notes) { %>
          <p class="text-sm text-[#8b8178] mt-2">
            <span class="text-[#c5973a] font-sans text-xs uppercase tracking-wider mr-2">注释</span>
            <span class="font-serif"><%= poem.notes %></span>
          </p>
        <% } %>
      </div>
    <% } %>

    <!-- Tags -->
    <% if (poem.tags && poem.tags.length > 0) { %>
      <div class="mt-6 flex flex-wrap gap-2">
        <% poem.tags.forEach(t => { %>
          <span class="text-xs bg-[#f7f3ee] border border-[#e8e2d8] text-[#8b8178] px-2.5 py-1 rounded-sm font-sans">
            #<%= t %>
          </span>
        <% }) %>
      </div>
    <% } %>

  </div>

  <!-- Navigation links -->
  <div class="flex flex-col-reverse sm:flex-row items-stretch sm:items-center justify-between gap-3 text-sm">
    <a href="/" class="text-center sm:text-left py-3 sm:py-0 text-[#8b8178] hover:text-[#c5973a] transition-colors font-sans min-h-[2.75rem] sm:min-h-0 flex items-center justify-center sm:justify-start [touch-action:manipulation]">
      ← 返回首页
    </a>
    <a href="/search" class="text-center sm:text-right py-3 sm:py-0 text-[#8b8178] hover:text-[#c5973a] transition-colors font-sans min-h-[2.75rem] sm:min-h-0 flex items-center justify-center sm:justify-end [touch-action:manipulation]">
      搜索 →
    </a>
  </div>

</main>

<%- include('partials/nav', { currentPage: 'poem' }) %>

</body>
</html>