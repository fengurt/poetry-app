<!DOCTYPE html>
<html lang="zh-CN" class="h-full">
<head>
  <meta charset="UTF-8">
  <%- include('partials/mobile-head') %>
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: { ink:'#1a1814', warm:'#f7f3ee', gold:'#c5973a', goldLt:'#e8d5a3', cream:'#faf8f5', muted:'#8b8178', stroke:'#e8e2d8' },
          fontFamily: { serif: ['Noto Serif SC','Georgia','serif'], sans: ['Inter','system-ui','sans-serif'] },
        }
      }
    }
  </script>
  <style>
    * { font-family: 'Inter','Noto Serif SC', sans-serif; }
    body { background: #faf8f5; }
    .card-ink { background: white; border: 1px solid #e8e2d8; box-shadow: 2px 2px 0 #c5973a18, 4px 4px 0 #c5973a08; }
    .poem-feed-card {
      position: relative;
      display: block;
      background: #fff;
      border: 1px solid #e4ddd4;
      border-radius: 12px;
      padding: 0.875rem 1rem 0.875rem 1.125rem;
      box-shadow: 0 1px 3px rgba(26, 24, 20, 0.05);
      transition: border-color 0.2s ease, box-shadow 0.2s ease;
      -webkit-tap-highlight-color: transparent;
      overflow-wrap: anywhere;
      word-break: break-word;
    }
    @media (min-width: 640px) {
      .poem-feed-card { padding: 1rem 1.125rem 1rem 1.25rem; border-radius: 14px; }
    }
    .poem-feed-card::before {
      content: '';
      position: absolute;
      left: 0.5rem;
      top: 0.75rem;
      bottom: 0.75rem;
      width: 3px;
      border-radius: 2px;
      background: linear-gradient(180deg, #d4a84a, #c5973a 40%, #a67c2e);
    }
    @media (hover: hover) and (pointer: fine) {
      .poem-feed-card:hover {
        border-color: #cfc5b8;
        box-shadow: 0 4px 20px rgba(26, 24, 20, 0.07);
      }
    }
    .poem-feed-card__head { padding-left: 0.35rem; }
    .poem-feed-card__title {
      font-family: 'Noto Serif SC', 'Georgia', serif;
      font-size: 1.0625rem;
      font-weight: 600;
      line-height: 1.35;
      color: #1a1814;
      margin: 0;
      letter-spacing: 0.02em;
    }
    @media (min-width: 640px) {
      .poem-feed-card__title { font-size: 1.125rem; }
    }
    .poem-feed-card__meta {
      margin: 0.35rem 0 0;
      padding-left: 0.35rem;
      font-family: Inter, system-ui, sans-serif;
      font-size: 0.75rem;
      line-height: 1.5;
      color: #7a726b;
    }
    @media (min-width: 640px) {
      .poem-feed-card__meta { font-size: 0.8125rem; }
    }
    .poem-feed-card__meta a {
      color: #1a1814;
      font-weight: 500;
      text-decoration: none;
    }
    .poem-feed-card__meta a:hover { color: #c5973a; }
    .poem-feed-card__sep { color: #c9c2b8; margin: 0 0.2em; }
    .poem-feed-card__verse {
      margin: 0.65rem 0 0;
      padding: 0.6rem 0 0;
      border-top: 1px solid #f0ebe4;
    }
    .poem-feed-card__line {
      font-family: 'Noto Serif SC', 'Georgia', serif;
      font-size: 0.9375rem;
      line-height: 1.95;
      color: #3d3833;
      margin: 0;
      text-align: start;
      letter-spacing: 0.03em;
    }
    .poem-feed-card__line--clamp {
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 6;
      overflow: hidden;
    }
    @media (min-width: 640px) {
      .poem-feed-card__line { font-size: 1rem; line-height: 2; }
    }
    .poem-feed-card__tags {
      margin: 0.5rem 0 0;
      padding-top: 0.45rem;
      font-family: Inter, system-ui, sans-serif;
      font-size: 0.6875rem;
      color: #a39a91;
      letter-spacing: 0.02em;
    }
    .poem-feed-card__tags-more { color: #c9c2b8; }
  </style>
</head>
<body class="min-h-full flex flex-col antialiased pad-bottom-nav">

<header class="sticky top-0 z-30 bg-[#faf8f5]/95 backdrop-blur-sm border-b border-[#e8e2d8]" style="padding-top: max(0px, env(safe-area-inset-top));">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-2 sm:py-2.5">
    <div class="flex flex-nowrap items-center gap-2 sm:gap-3 min-w-0">
      <a href="/" class="w-8 h-8 sm:w-7 sm:h-7 rounded-full bg-[#1a1814] flex items-center justify-center shrink-0 no-underline hover:opacity-90 [touch-action:manipulation]" aria-label="回首页">
        <span class="text-[#c5973a] text-xs font-serif font-bold">詩</span>
      </a>
      <h1 class="text-sm sm:text-base font-serif font-semibold text-[#1a1814] truncate shrink-0 max-w-[4.5rem] sm:max-w-[6rem]">搜索</h1>
      <form action="/search" method="get" class="flex-1 min-w-0">
        <div class="relative flex items-center">
          <input type="search" name="q" enterkeyhint="search" placeholder="搜索诗词、作者、内容分类…" value="<%= query %>"
                 class="w-full min-w-0 h-9 sm:h-10 pl-2.5 sm:pl-3 pr-11 sm:pr-12 rounded-sm border border-[#e8e2d8] bg-white text-sm text-[#1a1814] placeholder:text-[#b0a89e] focus:outline-none focus:border-[#c5973a] focus:ring-1 focus:ring-[#c5973a]/30 font-sans transition-colors">
          <button type="submit" class="absolute right-0.5 top-1/2 -translate-y-1/2 min-w-[2.25rem] min-h-[2.25rem] w-9 h-9 rounded-sm bg-[#1a1814] hover:bg-[#c5973a] text-white flex items-center justify-center shrink-0 [touch-action:manipulation]" aria-label="搜索">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="11" cy="11" r="6" stroke-width="1.5"/><path d="m16.5 16.5 3 3" stroke-width="1.5" stroke-linecap="round"/></svg>
          </button>
        </div>
      </form>
    </div>
  </div>
</header>

<main class="flex-1 max-w-6xl mx-auto px-4 sm:px-6 py-4 sm:py-6 w-full">

  <% if (query) { %>
    <div class="mb-6 pb-4 border-b border-[#e8e2d8] flex flex-col sm:flex-row sm:items-baseline gap-2 sm:gap-3 min-w-0">
      <span class="text-sm text-[#8b8178] font-sans">搜索结果</span>
      <span class="font-serif text-lg sm:text-xl font-semibold text-[#1a1814] break-words">"<%= query %>"</span>
      <span class="text-sm text-[#c5973a] font-sans sm:ml-auto"><%= poems.length %> 首</span>
    </div>
  <% } %>

  <% if (poems.length > 0) { %>
    <div class="flex flex-col gap-3 min-w-0">
      <% poems.forEach(p => { %>
        <% 
          const rawContent = p.content || '';
          const poemFlat = rawContent.replace(/\s+/g, ' ').trim();
          const verseLines = rawContent.split(/\n/).map(s => s.trim()).filter(Boolean);
          const verseIsMultiline = verseLines.length > 1;
          const previewMaxChars = 220;
          const previewMaxLines = 5;
          let previewLines = [];
          let used = 0;
          if (verseLines.length > 1) {
            for (const ln of verseLines) {
              if (previewLines.length >= previewMaxLines) break;
              if (used + ln.length > previewMaxChars) {
                const rest = previewMaxChars - used;
                if (rest > 8) previewLines.push(ln.slice(0, rest) + '…');
                used = previewMaxChars;
                break;
              }
              previewLines.push(ln);
              used += ln.length;
            }
          }
          if (previewLines.length === 0) {
            const one = poemFlat.slice(0, previewMaxChars) + (poemFlat.length > previewMaxChars ? '…' : '');
            previewLines = [one];
          }
        %>
        <a href="/poems/<%= p.id %>"
           class="poem-feed-card min-w-0 [touch-action:manipulation]"
           style="text-decoration:none">
          <header class="poem-feed-card__head">
            <h3 class="poem-feed-card__title line-clamp-3"><%= p.title %></h3>
            <p class="poem-feed-card__meta">
              <a href="/author/<%= encodeURIComponent(p.author_name) %>"><%= p.author_name %></a>
              <% if (p.poetry_type) { %><span class="poem-feed-card__sep">·</span><span><%= p.poetry_type %></span><% } %>
              <% if (p.category) { %><span class="poem-feed-card__sep">·</span><span><%= p.category %></span><% } %>
              <% if (p.publishYear) { %><span class="poem-feed-card__sep">·</span><span><%= p.publishYear %></span><% } %>
            </p>
          </header>
          <div class="poem-feed-card__verse" aria-label="节选">
            <% previewLines.forEach(function (line) { %>
              <p class="poem-feed-card__line<%= verseIsMultiline ? '' : ' poem-feed-card__line--clamp' %>"><%= line %></p>
            <% }) %>
          </div>
          <% if (p.nonYearTags && p.nonYearTags.length > 0) { %>
            <div class="poem-feed-card__tags px-1 pb-2">
              <% p.nonYearTags.slice(0, 4).forEach((t, i) => { %><% if (i) { %> <% } %>#<%= t %><% }) %>
              <% if (p.nonYearTags.length > 4) { %> <span class="poem-feed-card__tags-more">+<%= p.nonYearTags.length - 4 %></span><% } %>
            </div>
          <% } %>
        </a>
      <% }) %>
    </div>
  <% } else { %>
    <div class="card-ink py-10 px-6 sm:px-8 text-center rounded-sm">
      <div class="text-4xl mb-4">🔍</div>
      <% if (query) { %>
        <p class="font-serif text-lg text-[#1a1814] mb-2">未找到与 "<%= query %>" 相关的诗词</p>
        <p class="text-sm text-[#8b8178] mb-6">换个关键词试试吧</p>
      <% } else { %>
        <p class="font-serif text-lg text-[#1a1814] mb-2">输入关键词开始搜索</p>
        <p class="text-sm text-[#8b8178] mb-6">支持诗词标题、作者、内容分类、体裁、标签与发布年份等</p>
      <% } %>
      <a href="/" class="inline-block px-5 py-2 bg-[#1a1814] text-white text-sm font-sans rounded-sm hover:bg-[#c5973a] transition-colors">
        返回首页
      </a>
    </div>
  <% } %>

</main>

<%- include('partials/nav') %>

</body>
</html>